{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DouVoice",
  "version": "0.1.0",
  "identifier": "dou.voice",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Dou Voice",
        "width": 900,
        "height": 700,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
